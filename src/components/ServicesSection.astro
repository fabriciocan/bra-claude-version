---
const services = [
  {
    title: 'Diagnóstico do ambiente',
    desc: 'Entendemos pé-direito, área, umidade, temperatura, operação e pontos de risco antes de indicar qualquer solução.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  },
  {
    title: 'Projeto para resultado',
    desc: 'Definimos distribuição, potência, ângulo e proteção para melhorar visibilidade, segurança e consumo da operação.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>`,
  },
  {
    title: 'Especificação correta',
    desc: 'Você evita comprar luminária fraca, superdimensionada ou inadequada para poeira, umidade, calor e áreas externas.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>`,
  },
  {
    title: 'Menos parada e retrabalho',
    desc: 'Soluções duráveis reduzem trocas frequentes, chamados de manutenção e interrupções em áreas produtivas.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    title: 'Economia mensurável',
    desc: 'Apoiamos a decisão com estimativa de consumo, retorno do investimento e ganho esperado na conta de energia.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
  {
    title: 'Suporte depois da venda',
    desc: 'Acompanhamento técnico para ajustes, reposição e expansão do sistema conforme a operação evolui.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.64A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/></svg>`,
  },
];
---

<section style="padding: 80px 0; background: #fff;">
  <div class="container">
    <div style="text-align:center; margin-bottom:40px;">
      <p class="eyebrow" style="margin-bottom:8px">Como resolvemos</p>
      <h2 class="section-title">ILUMINAÇÃO COMO DECISÃO OPERACIONAL</h2>
      <p style="font-size:16px; color:#5A5A5A; max-width:560px; margin:12px auto 0; line-height:1.65">
        A luminária é só uma parte. O valor está em reduzir desperdício, aumentar segurança e manter a operação visível e estável.
      </p>
    </div>

    <div class="services-grid">
      {services.map(s => (
        <div class="service-card">
          <div class="service-card__icon">
            <span style="color:#E35106" set:html={s.icon} />
          </div>
          <div class="service-card__title">{s.title}</div>
          <p class="service-card__desc">{s.desc}</p>
        </div>
      ))}
    </div>

    <div style="text-align:center; margin-top:40px;">
      <a href="/contato" class="btn btn-primary">QUERO UMA ANÁLISE</a>
    </div>
  </div>
</section>
