---
const applications = [
  {
    label: 'Galpões Industriais',
    img: 'https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=800&q=80',
    alt: 'Interior de galpão industrial com iluminação LED',
  },
  {
    label: 'Frigoríficos',
    img: 'https://images.unsplash.com/photo-1574680178050-55c6a6a96e0a?w=800&q=80',
    alt: 'Câmara fria frigorífico iluminado',
  },
  {
    label: 'Centros Logísticos',
    img: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800&q=80',
    alt: 'Centro de distribuição logístico',
  },
  {
    label: 'Estacionamentos',
    img: 'https://images.unsplash.com/photo-1568605117036-5fe5e7bab0b7?w=800&q=80',
    alt: 'Estacionamento coberto iluminado',
  },
  {
    label: 'Quadras Esportivas',
    img: 'https://images.unsplash.com/photo-1546519638-68e109498ffc?w=800&q=80',
    alt: 'Quadra esportiva iluminada à noite',
  },
  {
    label: 'Armazéns',
    img: 'https://images.unsplash.com/photo-1553413077-190dd305871c?w=800&q=80',
    alt: 'Armazém com prateleiras e iluminação industrial',
  },
];
---

<section style="padding: 80px 0; background: #fff;">
  <div class="container">
    <div style="text-align:center; margin-bottom:40px;">
      <p class="eyebrow" style="margin-bottom:8px">Onde atuamos</p>
      <h2 class="section-title">APLICAÇÕES E AMBIENTES</h2>
      <p style="font-size:16px; color:#5A5A5A; max-width:560px; margin:12px auto 0; line-height:1.65">
        Soluções LED para os ambientes industriais mais exigentes do Brasil.
      </p>
    </div>

    <div class="applications-grid">
      {applications.map(app => (
        <div class="application-tile">
          <img
            src={app.img}
            alt={app.alt}
            class="application-tile__img"
            loading="lazy"
          />
          <div class="application-tile__overlay"></div>
          <div class="application-tile__label">{app.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
