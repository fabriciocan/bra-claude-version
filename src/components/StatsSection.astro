---
const stats = [
  { num: '-80%', label: 'Potencial de redução no consumo' },
  { num: '+50k', label: 'Horas para reduzir manutenção' },
  { num: 'IP68', label: 'Resistência para áreas críticas' },
  { num: '160', label: 'lm/W para maior rendimento' },
  { num: '~18m', label: 'Payback médio estimado' },
];
---

<section class="stats-band">
  <div class="container stats-band__inner">
    {stats.map(s => (
      <div class="stats-band__item">
        <div class="stats-band__num">{s.num}</div>
        <div class="stats-band__label">{s.label}</div>
      </div>
    ))}
  </div>
</section>
