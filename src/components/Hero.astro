---
// Hero section — homepage
---

<section class="hero">
  <div class="hero__grid" aria-hidden="true"></div>
  <div class="container hero__content">
    <p class="hero__eyebrow">Desde 2007 — Curitiba, PR</p>
    <h1 class="hero__headline">
      ILUMINAÇÃO LED<br>INDUSTRIAL
    </h1>
    <p class="hero__sub">
      Eficiência, durabilidade e economia para o seu negócio.<br>
      Soluções com IP65 a IP68 para ambientes industriais adversos.
    </p>

    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-num">80%</span>
        <span class="hero__stat-label">Economia energética</span>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-num">+50k</span>
        <span class="hero__stat-label">Horas de vida útil</span>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-num">IP68</span>
        <span class="hero__stat-label">Proteção máxima</span>
      </div>
    </div>

    <div class="hero__ctas">
      <a href="/produtos" class="btn btn-primary">VER PRODUTOS</a>
      <a href="/contato" class="btn btn-secondary">SOLICITAR ORÇAMENTO</a>
    </div>
  </div>
</section>
