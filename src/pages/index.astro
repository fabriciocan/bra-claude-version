---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import StatsSection from '../components/StatsSection.astro';
import ApplicationsSection from '../components/ApplicationsSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import { getProducts, getTestimonials, getSiteSettings } from '../lib/queries';
import type { Product } from '../lib/queries';

const [products, testimonials, settings] = await Promise.all([
  getProducts(),
  getTestimonials(),
  getSiteSettings(),
]);

const featuredProducts = products.filter(p => p.featured).slice(0, 6);
const displayProducts = featuredProducts.length >= 3 ? featuredProducts : products.slice(0, 6);
---

<BaseLayout title="Iluminação LED Industrial">
  <Header currentPage="home" />

  <main>
    <Hero />
    <StatsSection />

    <!-- Featured products section -->
    <section style="padding:80px 0; background:#F5F5F5;">
      <div class="container">
        <div style="text-align:center; margin-bottom:40px;">
          <p class="eyebrow" style="margin-bottom:8px">Catálogo</p>
          <h2 class="section-title">PRODUTOS EM DESTAQUE</h2>
          <p style="font-size:16px;color:#5A5A5A;max-width:560px;margin:12px auto 0;line-height:1.65">
            Soluções completas em iluminação industrial — Highbay, Projetores e Emergência.
          </p>
        </div>

        <div class="products-grid">
          {displayProducts.map((p: Product) => (
            <article class="product-card">
              {p.badge && (
                <div class="product-card__badge">
                  <span class="badge" style={`background:${p.badgeColor || '#E35106'}`}>{p.badge}</span>
                </div>
              )}
              <a href={`/produtos/${p.slug}`} class="product-card__img-wrap" aria-label={`Ver ${p.fullName}`}>
                <img
                  src={p.imageUrl || '/placeholder-product.jpg'}
                  alt={p.fullName}
                  class="product-card__img"
                  loading="lazy"
                  width="300"
                  height="200"
                />
              </a>
              <div class="product-card__body">
                <div class="product-card__cat">{p.category}</div>
                <a href={`/produtos/${p.slug}`} class="product-card__name">{p.name}</a>
                {p.specs.length > 0 && (
                  <div class="product-card__chips">
                    {p.specs.slice(0, 3).map(s => (
                      <span class="chip" title={s.key}>{s.value}</span>
                    ))}
                  </div>
                )}
                <p class="product-card__desc">{p.shortDesc}</p>
                <div class="product-card__actions">
                  <a href={`/produtos/${p.slug}`} class="product-card__detail">Ver ficha técnica →</a>
                  <a href={`/contato?produto=${p.slug}`} class="product-card__cta">Orçamento</a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div style="text-align:center; margin-top:32px;">
          <a href="/produtos" class="btn btn-dark">VER TODOS OS PRODUTOS</a>
        </div>
      </div>
    </section>

    <!-- About section -->
    <section style="padding:80px 0; background:#F5F5F5;" id="sobre">
      <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;">
        <div>
          <p class="eyebrow" style="margin-bottom:12px">Quem somos</p>
          <h2 class="section-title" style="margin-bottom:20px">O FUTURO DA ILUMINAÇÃO INDUSTRIAL</h2>
          <p style="font-size:16px;color:#5A5A5A;line-height:1.7;margin-bottom:16px">
            A iluminação LED industrial representa uma revolução no setor produtivo, combinando eficiência energética incomparável com durabilidade excepcional.
          </p>
          <p style="font-size:16px;color:#5A5A5A;line-height:1.7;margin-bottom:28px">
            Desde 2007, a BRALARMSEG atua em Curitiba/PR fornecendo soluções completas para galpões industriais, frigoríficos, centros logísticos, estacionamentos, portos, aeroportos, supermercados e quadras esportivas.
          </p>
          <div style="display:flex;flex-direction:column;gap:10px">
            {[
              'Redução de até 70% no consumo energético',
              'Menor necessidade de manutenção',
              'Sustentável e de longa vida útil',
              'Produtos com grau IP65 a IP68',
            ].map(item => (
              <div style="display:flex;align-items:center;gap:10px;font-size:14px;color:#3A3A3A">
                <div style="width:6px;height:6px;background:#E35106;border-radius:50%;flex-shrink:0"></div>
                {item}
              </div>
            ))}
          </div>
        </div>
        <div style="background:#0A1628;border-radius:4px;padding:40px;display:grid;grid-template-columns:1fr 1fr;gap:24px;">
          {[['Desde','2007'],['+50.000','Horas de vida'],[' IP68','Proteção máx.'],['80%','Menos consumo']].map(([num,lbl]) => (
            <div style="text-align:center">
              <div style="font-family:'Barlow Condensed',sans-serif;font-size:40px;font-weight:800;color:#E35106;line-height:1">{num}</div>
              <div style="font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#5A7AA0;margin-top:6px">{lbl}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <ApplicationsSection />
    <ServicesSection />
    <TestimonialsSection testimonials={testimonials} />
  </main>

  <Footer settings={settings} />
</BaseLayout>

<style>
  @media (max-width: 900px) {
    section > .container[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
