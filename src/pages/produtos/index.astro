---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getProducts, getSiteSettings } from '../../lib/queries';
import type { Product } from '../../lib/queries';

const [products, settings] = await Promise.all([getProducts(), getSiteSettings()]);

const ledProducts = products.filter(p => p.productLine === 'led');
const emergProducts = products.filter(p => p.productLine === 'emergencia');

const ledCats     = ['Todos', ...new Set(ledProducts.map(p => p.category))];
const emergCats   = ['Todos', ...new Set(emergProducts.map(p => p.category))];

const miniLed   = ledProducts.map(p => ({ slug: p.slug, name: p.name.toLowerCase(), shortDesc: p.shortDesc.toLowerCase(), category: p.category }));
const miniEmerg = emergProducts.map(p => ({ slug: p.slug, name: p.name.toLowerCase(), shortDesc: p.shortDesc.toLowerCase(), category: p.category }));
---

<BaseLayout
  title="Catálogo de Produtos"
  description="Catálogo BRATECH: Luminárias LED industriais e Luminárias de Emergência. Highbay, Projetores UFO, Projetores e Emergência IP66/68."
>
  <Header currentPage="produtos" />

  <main x-data="catalog" x-init="init()">

    <!-- Page header -->
    <div class="page-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/" class="breadcrumb__item">BRATECH</a>
          <span class="breadcrumb__sep">/</span>
          <span class="breadcrumb__item breadcrumb__item--current">Catálogo</span>
        </nav>
        <h1 class="page-header__title" style="margin-top:10px">CATÁLOGO DE LUMINÁRIAS</h1>
        <p class="page-header__sub">Luminária LED Industrial e Luminária de Emergência — soluções para cada ambiente.</p>
      </div>
    </div>

    <!-- Main line tabs -->
    <div style="background:#fff;border-bottom:2px solid #EBEBEB;">
      <div class="container">
        <div style="display:flex;gap:0;">
          <button
            class="line-tab"
            :class="activeLine==='led'?'line-tab--active':''"
            @click="activeLine='led';category='Todos'"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            Luminária LED
          </button>
          <button
            class="line-tab"
            :class="activeLine==='emergencia'?'line-tab--active':''"
            @click="activeLine='emergencia';category='Todos'"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Luminária de Emergência
          </button>
        </div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="catalog-toolbar">
      <div class="catalog-toolbar__inner">
        <!-- Search -->
        <div class="search-wrap">
          <svg class="search-wrap__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input type="text" class="search-input" placeholder="Buscar produto..."
            x-model="search" @input.debounce.200ms="filterNow()" aria-label="Buscar produto" />
        </div>

        <!-- Sub-category tabs — LED (shown when activeLine === 'led') -->
        <div class="cat-tabs" role="tablist" x-show="activeLine==='led'">
          {ledCats.map(cat => (
            <button class="cat-tab" :class={`category==='${cat}'?'cat-tab--active':''`} @click={`category='${cat}';filterNow()`} role="tab">{cat}</button>
          ))}
        </div>

        <!-- Sub-category tabs — Emergência (shown when activeLine === 'emergencia') -->
        <div class="cat-tabs" role="tablist" x-show="activeLine==='emergencia'">
          {emergCats.map(cat => (
            <button class="cat-tab" :class={`category==='${cat}'?'cat-tab--active':''`} @click={`category='${cat}';filterNow()`} role="tab">{cat}</button>
          ))}
        </div>

        <!-- Right controls -->
        <div class="toolbar-right">
          <!-- AI Simulator button -->
          <button class="btn-simulate" @click="showSimulator=true" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Simular com IA
          </button>

          <select class="sort-select" x-model="sort" @change="filterNow()" aria-label="Ordenar">
            <option value="default">Ordenar por...</option>
            <option value="name">Nome A–Z</option>
            <option value="category">Categoria</option>
          </select>
          <div class="view-toggle">
            <button class="view-btn" :class="view==='grid'?'view-btn--active':''" @click="view='grid'" title="Grade">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            </button>
            <button class="view-btn" :class="view==='list'?'view-btn--active':''" @click="view='list'" title="Lista">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="container" style="padding-top:20px;padding-bottom:80px">
      <!-- Results bar -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px">
        <span style="font-size:12px;color:#7A7A7A;font-weight:500"
          x-text="`${visCount} produto${visCount!==1?'s':''} encontrado${visCount!==1?'s':''}`"></span>
      </div>

      <!-- Empty state -->
      <div x-show="visCount===0" class="no-results">
        <div class="no-results__icon">○</div>
        <p class="no-results__title">Nenhum produto encontrado</p>
        <p style="color:#7A7A7A;font-size:14px">Tente outra categoria ou limpe a busca.</p>
        <button class="btn btn-ghost" style="margin-top:20px" @click="search='';category='Todos';filterNow()">Limpar filtros</button>
      </div>

      <!-- GRID VIEW — LED -->
      <div x-show="view==='grid' && activeLine==='led'" class="products-grid">
        {ledProducts.map((p: Product) => (
          <article class="product-card" data-cat={p.category} data-search={`${p.name} ${p.shortDesc} ${p.badge||''}`.toLowerCase()} x-show="vis($el)">
            {p.badge && <div class="product-card__badge"><span class="badge" style={`background:${p.badgeColor||'#E35106'}`}>{p.badge}</span></div>}
            <a href={`/produtos/${p.slug}`} class="product-card__img-wrap">
              <img src={p.imageUrl || `https://placehold.co/300x200/F5F5F5/8A8A8A?text=${encodeURIComponent(p.name)}`} alt={p.fullName} class="product-card__img" loading="lazy" width="300" height="200" />
            </a>
            <div class="product-card__body">
              <div class="product-card__cat">{p.category}</div>
              <a href={`/produtos/${p.slug}`} class="product-card__name">{p.name}</a>
              {p.specs.length > 0 && <div class="product-card__chips">{p.specs.slice(0,3).map(s => <span class="chip" title={s.key}>{s.value}</span>)}</div>}
              <p class="product-card__desc">{p.shortDesc}</p>
              <div class="product-card__actions">
                <a href={`/produtos/${p.slug}`} class="product-card__detail">Ver ficha técnica →</a>
                <a href={`/contato?produto=${p.slug}`} class="product-card__cta">Orçamento</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- GRID VIEW — Emergência -->
      <div x-show="view==='grid' && activeLine==='emergencia'" class="products-grid">
        {emergProducts.map((p: Product) => (
          <article class="product-card" data-cat={p.category} data-search={`${p.name} ${p.shortDesc} ${p.badge||''}`.toLowerCase()} x-show="vis($el)">
            {p.badge && <div class="product-card__badge"><span class="badge" style={`background:${p.badgeColor||'#E35106'}`}>{p.badge}</span></div>}
            <a href={`/produtos/${p.slug}`} class="product-card__img-wrap">
              <img src={p.imageUrl || `https://placehold.co/300x200/F5F5F5/8A8A8A?text=${encodeURIComponent(p.name)}`} alt={p.fullName} class="product-card__img" loading="lazy" width="300" height="200" />
            </a>
            <div class="product-card__body">
              <div class="product-card__cat" style="color:#DC2626">{p.category}</div>
              <a href={`/produtos/${p.slug}`} class="product-card__name">{p.name}</a>
              {p.specs.length > 0 && <div class="product-card__chips">{p.specs.slice(0,3).map(s => <span class="chip" title={s.key}>{s.value}</span>)}</div>}
              <p class="product-card__desc">{p.shortDesc}</p>
              <div class="product-card__actions">
                <a href={`/produtos/${p.slug}`} class="product-card__detail">Ver ficha técnica →</a>
                <a href={`/contato?produto=${p.slug}`} class="product-card__cta">Orçamento</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- LIST VIEW — LED -->
      <div x-show="view==='list' && activeLine==='led'" style="display:flex;flex-direction:column;gap:8px">
        {ledProducts.map((p: Product) => (
          <div class="list-row" data-cat={p.category} data-search={`${p.name} ${p.shortDesc} ${p.badge||''}`.toLowerCase()} x-show="vis($el)">
            <a href={`/produtos/${p.slug}`} class="list-row__img-wrap">
              <img src={p.imageUrl||`https://placehold.co/80x60/F5F5F5/8A8A8A?text=${encodeURIComponent(p.name)}`} alt={p.fullName} class="list-row__img" loading="lazy" />
            </a>
            <div class="list-row__info">
              <div class="list-row__cat">{p.category}</div>
              <a href={`/produtos/${p.slug}`} class="list-row__name">{p.name}</a>
              <p class="list-row__desc">{p.shortDesc}</p>
            </div>
            <div class="list-row__specs">
              {p.specs.slice(0,4).map(s => <div class="list-row__spec-row"><span class="list-row__spec-key">{s.key}:</span><span class="list-row__spec-val">{s.value}</span></div>)}
            </div>
            <div class="list-row__actions">
              {p.badge && <span class="badge" style={`background:${p.badgeColor||'#E35106'}`}>{p.badge}</span>}
              <a href={`/produtos/${p.slug}`} class="btn btn-ghost btn-sm">Ficha técnica</a>
              <a href={`/contato?produto=${p.slug}`} class="btn btn-primary btn-sm">Orçamento</a>
            </div>
          </div>
        ))}
      </div>

      <!-- LIST VIEW — Emergência -->
      <div x-show="view==='list' && activeLine==='emergencia'" style="display:flex;flex-direction:column;gap:8px">
        {emergProducts.map((p: Product) => (
          <div class="list-row" data-cat={p.category} data-search={`${p.name} ${p.shortDesc} ${p.badge||''}`.toLowerCase()} x-show="vis($el)">
            <a href={`/produtos/${p.slug}`} class="list-row__img-wrap">
              <img src={p.imageUrl||`https://placehold.co/80x60/F5F5F5/8A8A8A?text=${encodeURIComponent(p.name)}`} alt={p.fullName} class="list-row__img" loading="lazy" />
            </a>
            <div class="list-row__info">
              <div class="list-row__cat" style="color:#DC2626">{p.category}</div>
              <a href={`/produtos/${p.slug}`} class="list-row__name">{p.name}</a>
              <p class="list-row__desc">{p.shortDesc}</p>
            </div>
            <div class="list-row__specs">
              {p.specs.slice(0,4).map(s => <div class="list-row__spec-row"><span class="list-row__spec-key">{s.key}:</span><span class="list-row__spec-val">{s.value}</span></div>)}
            </div>
            <div class="list-row__actions">
              {p.badge && <span class="badge" style={`background:${p.badgeColor||'#E35106'}`}>{p.badge}</span>}
              <a href={`/produtos/${p.slug}`} class="btn btn-ghost btn-sm">Ficha técnica</a>
              <a href={`/contato?produto=${p.slug}`} class="btn btn-primary btn-sm">Orçamento</a>
            </div>
          </div>
        ))}
      </div>

    </div><!-- /container -->

    <!-- ═══════════════════════════════════════════
         AI SIMULATOR MODAL
    ══════════════════════════════════════════════ -->
    <div
      x-show="showSimulator"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      style="display:none;position:fixed;inset:0;z-index:400;background:rgba(6,13,26,0.75);overflow-y:auto;padding:32px 16px"
      @click.self="closeSimulator()"
    >
      <div
        x-show="showSimulator"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 scale-95"
        x-transition:enter-end="opacity-100 scale-100"
        style="max-width:600px;margin:0 auto;background:#fff;border-radius:6px;overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,0.4)"
      >
        <!-- Modal header -->
        <div style="background:#0A1628;padding:24px 28px;display:flex;align-items:center;justify-content:space-between">
          <div>
            <div style="font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#E35106;margin-bottom:4px">Inteligência Artificial</div>
            <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;color:#fff;letter-spacing:-0.01em;margin:0">SIMULAR LUMINÁRIA IDEAL</h2>
          </div>
          <button @click="closeSimulator()" style="background:rgba(255,255,255,0.1);border:none;color:#fff;width:36px;height:36px;border-radius:4px;font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center" aria-label="Fechar">×</button>
        </div>

        <!-- FORM STATE -->
        <div x-show="simState==='form'" style="padding:28px">
          <p style="font-size:14px;color:#5A5A5A;margin-bottom:24px;line-height:1.6">Preencha os dados da sua instalação e a IA recomendará as melhores luminárias do nosso portfólio.</p>

          <form @submit.prevent="runSimulation()" style="display:flex;flex-direction:column;gap:16px">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
              <div class="field">
                <label for="sim-ambiente">Tipo de ambiente</label>
                <select id="sim-ambiente" x-model="simForm.ambiente" required>
                  <option value="">Selecione...</option>
                  <option>Galpão industrial</option>
                  <option>Frigorífico / câmara fria</option>
                  <option>Supermercado</option>
                  <option>Escritório / comercial</option>
                  <option>Quadra esportiva</option>
                  <option>Estacionamento</option>
                  <option>Área portuária / aeroporto</option>
                  <option>Pátio externo</option>
                  <option>Fundição / petroquímica</option>
                  <option>Outro</option>
                </select>
              </div>
              <div class="field">
                <label for="sim-altura">Pé-direito / altura</label>
                <select id="sim-altura" x-model="simForm.altura" required>
                  <option value="">Selecione...</option>
                  <option>Até 4 m</option>
                  <option>4 a 8 m</option>
                  <option>8 a 12 m</option>
                  <option>Acima de 12 m</option>
                </select>
              </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
              <div class="field">
                <label for="sim-area">Área total (m²)</label>
                <input id="sim-area" type="number" min="1" placeholder="ex: 500" x-model="simForm.area" required />
              </div>
              <div class="field">
                <label for="sim-tensao">Tensão disponível</label>
                <select id="sim-tensao" x-model="simForm.tensao">
                  <option>Bivolt (110/220V)</option>
                  <option>220V</option>
                  <option>110V</option>
                  <option>24Vdc (solar/off-grid)</option>
                </select>
              </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:center">
              <div class="field">
                <label>Localização</label>
                <div style="display:flex;gap:16px;margin-top:4px">
                  <label style="display:flex;align-items:center;gap:6px;font-size:14px;font-weight:400;cursor:pointer">
                    <input type="radio" x-model="simForm.local" value="interno" style="accent-color:#E35106" /> Interno
                  </label>
                  <label style="display:flex;align-items:center;gap:6px;font-size:14px;font-weight:400;cursor:pointer">
                    <input type="radio" x-model="simForm.local" value="externo" style="accent-color:#E35106" /> Externo
                  </label>
                </div>
              </div>
              <div class="field">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:400;font-size:14px">
                  <input type="checkbox" x-model="simForm.emergencia" style="accent-color:#DC2626;width:16px;height:16px" />
                  <span>Necessita iluminação<br>de emergência</span>
                </label>
              </div>
            </div>

            <div class="field">
              <label for="sim-obs">Observações (opcional)</label>
              <textarea id="sim-obs" x-model="simForm.obs" placeholder="Ex: Ambiente com umidade alta, necessita IP65+" style="min-height:60px"></textarea>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:14px">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              SIMULAR COM IA
            </button>
          </form>
        </div>

        <!-- LOADING STATE -->
        <div x-show="simState==='loading'" style="padding:64px 28px;text-align:center">
          <div class="sim-spinner" style="margin:0 auto 20px"></div>
          <p style="font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:700;color:#0A1628">Analisando seu projeto...</p>
          <p style="font-size:13px;color:#7A7A7A;margin-top:6px">A IA está selecionando as melhores luminárias para você.</p>
        </div>

        <!-- RESULTS STATE -->
        <div x-show="simState==='results'" style="padding:28px">
          <!-- Reasoning -->
          <div style="background:#F5F5F5;border-left:3px solid #E35106;padding:14px 16px;border-radius:0 4px 4px 0;margin-bottom:20px">
            <div style="font-size:10px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#E35106;margin-bottom:6px">Análise da IA</div>
            <p style="font-size:13px;color:#3A3A3A;line-height:1.65" x-text="simResults.reasoning"></p>
          </div>

          <!-- Recommended products -->
          <div style="font-size:10px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#5A5A5A;margin-bottom:12px">Luminárias recomendadas</div>
          <div style="display:flex;flex-direction:column;gap:12px">
            <template x-for="rec in simResults.products" :key="rec.slug">
              <div style="display:flex;align-items:flex-start;gap:14px;padding:14px;border:1px solid #DCDCDC;border-radius:4px;background:#fff">
                <div style="flex-shrink:0;width:32px;height:32px;background:#E35106;border-radius:3px;display:flex;align-items:center;justify-content:center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div style="flex:1;min-width:0">
                  <div style="font-family:'Barlow Condensed',sans-serif;font-size:17px;font-weight:700;color:#111" x-text="rec.name"></div>
                  <div style="font-size:12px;color:#5A5A5A;margin-top:3px;line-height:1.5" x-text="rec.reason"></div>
                </div>
                <a :href="`/produtos/${rec.slug}`" class="btn btn-primary btn-sm" style="flex-shrink:0;white-space:nowrap">Ver produto</a>
              </div>
            </template>
          </div>

          <!-- Error state -->
          <div x-show="simResults.error" style="background:#FEE2E2;border:1px solid #FECACA;border-radius:4px;padding:14px;margin-bottom:16px">
            <p style="font-size:13px;color:#991B1B" x-text="simResults.error"></p>
          </div>

          <div style="display:flex;gap:10px;margin-top:20px">
            <button @click="simState='form'" class="btn btn-ghost" style="flex:1;justify-content:center">Simular novamente</button>
            <a href="/contato" class="btn btn-primary" style="flex:1;justify-content:center;text-decoration:none">Solicitar orçamento</a>
          </div>
        </div>

      </div>
    </div>

  </main>

  <Footer settings={settings} />
</BaseLayout>

<style>
  .line-tab {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 16px 28px; background: none; border: none; border-bottom: 3px solid transparent;
    cursor: pointer; color: #7A7A7A; display: flex; align-items: center; gap: 8px;
    transition: color 150ms, border-color 150ms; margin-bottom: -2px;
  }
  .line-tab:hover { color: #111; }
  .line-tab--active { color: #E35106; border-bottom-color: #E35106; }
  .btn-simulate {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    display: flex; align-items: center; gap: 6px;
    background: linear-gradient(135deg, #0A1628, #1A3A60);
    color: #fff; border: none; padding: 8px 16px; border-radius: 3px;
    cursor: pointer; white-space: nowrap; transition: opacity 150ms;
  }
  .btn-simulate:hover { opacity: 0.85; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .sim-spinner {
    width: 48px; height: 48px; border: 4px solid #EBEBEB;
    border-top-color: #E35106; border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @media (max-width: 640px) {
    .line-tab { padding: 12px 16px; font-size: 13px; }
  }
</style>

<script define:vars={{ miniLed, miniEmerg }} is:inline>
  window.__BRA_LED__   = miniLed;
  window.__BRA_EMERG__ = miniEmerg;
</script>

<script is:inline>
  document.addEventListener('alpine:init', function () {
    Alpine.data('catalog', function () {
      return {
        activeLine: 'led',
        search:   '',
        category: 'Todos',
        sort:     'default',
        view:     'grid',
        showSimulator: false,
        simState: 'form',
        simForm: {
          ambiente: '', altura: '', area: '', tensao: 'Bivolt (110/220V)',
          local: 'interno', emergencia: false, obs: ''
        },
        simResults: { reasoning: '', products: [], error: '' },

        init: function () {
          var params = new URLSearchParams(window.location.search);
          var linha = params.get('linha') || params.get('line');
          var cat = params.get('cat');

          if (linha === 'led' || linha === 'emergencia') {
            this.activeLine = linha;
            this.category = 'Todos';
          }

          if (cat) this.category = cat;
          if (params.get('simular') === 'ia') this.showSimulator = true;
        },

        get currentMini() {
          return this.activeLine === 'led'
            ? (window.__BRA_LED__   || [])
            : (window.__BRA_EMERG__ || []);
        },

        get visCount() {
          var q    = this.search.trim().toLowerCase();
          var self = this;
          return this.currentMini.filter(function (p) {
            var okCat = self.category === 'Todos' || p.category === self.category;
            var okSrc = !q || p.name.includes(q) || p.shortDesc.includes(q);
            return okCat && okSrc;
          }).length;
        },

        vis: function (el) {
          var cat    = (el.dataset.cat    || '').trim();
          var search = (el.dataset.search || '').trim();
          var okCat  = this.category === 'Todos' || cat === this.category;
          var q      = this.search.trim().toLowerCase();
          var okSrc  = !q || search.includes(q);
          return okCat && okSrc;
        },

        filterNow: function () { /* reactive */ },

        closeSimulator: function () {
          this.showSimulator = false;
          this.simState = 'form';
        },

        runSimulation: async function () {
          this.simState = 'loading';
          try {
            var resp = await fetch('/api/simulate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(this.simForm),
            });
            if (!resp.ok) throw new Error('Erro ' + resp.status);
            var data = await resp.json();
            this.simResults = data;
            this.simState = 'results';
          } catch (err) {
            this.simResults = {
              reasoning: 'Não foi possível conectar ao serviço de IA. Exibindo recomendações padrão baseadas nos dados fornecidos.',
              products: this.fallbackRec(),
              error: ''
            };
            this.simState = 'results';
          }
        },

        fallbackRec: function () {
          var f = this.simForm;
          var recs = [];
          if (f.emergencia) {
            if (f.local === 'externo') {
              recs.push({ slug: 'almba2f', name: 'ALMBA2F', reason: 'Uso externo IP66/68 com 7h de autonomia, ideal para o ambiente indicado.' });
            } else {
              recs.push({ slug: 'almipl', name: 'ALMIPL', reason: 'Luminária interna IP20 com 5h de autonomia para saídas de emergência.' });
            }
          }
          if (f.altura === 'Acima de 12 m' || f.altura === '8 a 12 m') {
            recs.push({ slug: 'highbay-magna', name: 'HIGHBAY MAGNA', reason: 'Alta potência e IP66 para grandes pés-direitos industriais.' });
          } else if (f.local === 'externo') {
            recs.push({ slug: 'projetor-vegas', name: 'VEGAS', reason: 'Projetor IP66 com ângulo ajustável para áreas externas.' });
          } else {
            recs.push({ slug: 'ufo-elite', name: 'UFO ELITE', reason: '160lm/W para máxima eficiência energética em ambientes internos.' });
          }
          return recs;
        },
      };
    });
  });
</script>
