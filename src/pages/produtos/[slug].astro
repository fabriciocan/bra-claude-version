---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getProductBySlug, getProducts, getSiteSettings } from '../../lib/queries';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/produtos');

const [product, settings] = await Promise.all([
  getProductBySlug(slug),
  getSiteSettings(),
]);

if (!product) return Astro.redirect('/produtos');

const half = Math.ceil(product.specs.length / 2);
const specsFirst = product.specs.slice(0, half);
const specsSecond = product.specs.slice(half);
const garantia = product.specs.find(s => s.key === 'Garantia')?.value || '2 anos';
---

<BaseLayout
  title={product.fullName || product.name}
  description={product.shortDesc}
>
  <Header currentPage="produtos" />

  <main>
    <!-- Breadcrumb bar -->
    <div style="background:#fff;border-bottom:1px solid #EBEBEB">
      <div class="container" style="padding-top:10px;padding-bottom:10px;display:flex;align-items:center;gap:20px;flex-wrap:wrap">
        <a href="/produtos" style="font-size:12px;font-weight:600;color:#5A5A5A;text-decoration:none;display:flex;align-items:center;gap:4px">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          Voltar ao catálogo
        </a>
        <nav class="breadcrumb" aria-label="Navegação estrutural">
          <a href="/" class="breadcrumb__item">BRALARMSEG</a>
          <span class="breadcrumb__sep">/</span>
          <a href="/produtos" class="breadcrumb__item">Catálogo</a>
          <span class="breadcrumb__sep">/</span>
          <a href={`/produtos?cat=${encodeURIComponent(product.category)}`} class="breadcrumb__item">{product.category}</a>
          <span class="breadcrumb__sep">/</span>
          <span class="breadcrumb__item breadcrumb__item--current">{product.name}</span>
        </nav>
      </div>
    </div>

    <!-- Product main layout -->
    <div style="background:#F5F5F5;min-height:calc(100vh - 200px)">
      <div class="container product-detail-grid">

        <!-- Left col: image + certs -->
        <div style="display:flex;flex-direction:column;gap:16px">
          <div class="product-detail__img-wrap">
            <img
              src={product.imageUrl || '/placeholder-product.jpg'}
              alt={product.fullName}
              class="product-detail__img"
              width="380"
              height="320"
            />
          </div>

          <!-- Certifications -->
          {product.certifications.length > 0 && (
            <div class="product-detail__certs-wrap">
              <div class="product-detail__certs-label">Certificações</div>
              <div class="product-detail__certs-row">
                {product.certifications.map(c => (
                  <span class="cert-badge">{c}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Compare button (Alpine) -->
          <div x-data="compareBtn()" x-init="init()">
            <button
              :class="isCompared ? 'btn btn-dark' : 'btn btn-ghost'"
              style="width:100%;display:flex;align-items:center;justify-content:center;gap:8px"
              @click="toggle()"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
              <span x-text="isCompared ? 'Remover da comparação' : 'Adicionar à comparação'"></span>
            </button>
          </div>
        </div>

        <!-- Right col: info -->
        <div style="display:flex;flex-direction:column;gap:0">
          {product.badge && (
            <div style="margin-bottom:10px">
              <span class="badge" style={`background:${product.badgeColor || '#E35106'}`}>{product.badge}</span>
            </div>
          )}

          <div style="font-size:11px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#E35106;margin-bottom:6px">
            {product.category}
          </div>

          <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(28px,4vw,40px);font-weight:800;color:#111;line-height:1.05;letter-spacing:-0.01em;margin-bottom:16px">
            {(product.fullName || product.name).toUpperCase()}
          </h1>

          <p style="font-size:15px;color:#4A4A4A;line-height:1.7;margin-bottom:24px">
            {product.longDesc}
          </p>

          <!-- Quick specs -->
          {product.specs.length > 0 && (
            <div class="product-detail__quick-specs" style="margin-bottom:20px">
              {product.specs.slice(0, 4).map(s => (
                <div class="quick-spec">
                  <div class="quick-spec__val">{s.value}</div>
                  <div class="quick-spec__key">{s.key}</div>
                </div>
              ))}
            </div>
          )}

          <!-- Applications -->
          {product.applications.length > 0 && (
            <div style="margin-bottom:24px">
              <div style="font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#7A7A7A;margin-bottom:8px">
                Aplicações
              </div>
              <div style="display:flex;gap:6px;flex-wrap:wrap">
                {product.applications.map(a => (
                  <span style="font-size:12px;font-weight:500;background:#F0F0F0;color:#3A3A3A;padding:4px 10px;border-radius:3px;border:1px solid #EBEBEB">{a}</span>
                ))}
              </div>
            </div>
          )}

          <!-- CTAs -->
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <a href={`/contato?produto=${product.slug}`} class="btn btn-primary" style="flex:1;min-width:160px">
              SOLICITAR ORÇAMENTO
            </a>
            <a
              href={`https://wa.me/${settings.whatsapp}?text=Olá,%20tenho%20interesse%20no%20produto%20${encodeURIComponent(product.fullName || product.name)}.`}
              target="_blank"
              rel="noopener"
              class="btn btn-outline"
            >
              WHATSAPP
            </a>
          </div>
        </div>
      </div>

      <!-- Tabs section -->
      <div style="background:#fff;border-top:1px solid #EBEBEB">
        <div class="container" style="padding-bottom:40px">
          <div
            x-data="{ activeTab: 'specs' }"
          >
            <div class="tabs" role="tablist">
              {[
                ['specs', 'Especificações Técnicas'],
                ['warranty', 'Garantia & Suporte'],
                ['downloads', 'Downloads'],
              ].map(([id, label]) => (
                <button
                  class="tab-btn"
                  :class={`{'tab-btn--active': activeTab === '${id}'}`}
                  @click={`activeTab = '${id}'`}
                  role="tab"
                  :aria-selected={`activeTab === '${id}'`}
                >
                  {label}
                </button>
              ))}
            </div>

            <!-- Specs tab -->
            <div x-show="activeTab === 'specs'">
              <div class="specs-grid">
                <table class="specs-table">
                  <tbody>
                    {specsFirst.map(s => (
                      <tr class="spec-row">
                        <td class="spec-key">{s.key}</td>
                        <td class="spec-val">{s.value}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
                <table class="specs-table">
                  <tbody>
                    {specsSecond.map(s => (
                      <tr class="spec-row">
                        <td class="spec-key">{s.key}</td>
                        <td class="spec-val">{s.value}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Warranty tab -->
            <div x-show="activeTab === 'warranty'" style="padding:28px 0">
              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px">
                {[
                  ['Garantia do produto', garantia, 'Cobre defeitos de fabricação e falhas de componentes em condições normais de uso.'],
                  ['Suporte técnico', 'Pós-venda', 'Equipe especializada disponível para assistência técnica e orientação de instalação.'],
                  ['Reposição de peça', 'Conforme garantia', 'Peças e componentes originais disponíveis para reposição durante o período de garantia.'],
                ].map(([title, val, desc]) => (
                  <div style="padding:20px;background:#F5F5F5;border-radius:3px;border:1px solid #EBEBEB">
                    <div style="font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:800;color:#E35106;line-height:1;margin-bottom:6px">{val}</div>
                    <div style="font-size:13px;font-weight:600;color:#111;margin-bottom:6px">{title}</div>
                    <p style="font-size:13px;color:#5A5A5A;line-height:1.6">{desc}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Downloads tab -->
            <div x-show="activeTab === 'downloads'" style="padding:28px 0;display:flex;flex-direction:column;gap:10px">
              {[
                [`Datasheet técnico — ${product.name}`, 'PDF', '284 KB'],
                ['Manual de instalação', 'PDF', '1,2 MB'],
                ['Certificado INMETRO', 'PDF', '156 KB'],
                ['Fotometria IES/LDT', 'IES', '48 KB'],
              ].map(([name, type, size]) => (
                <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:#fff;border:1px solid #EBEBEB;border-radius:3px">
                  <div style="display:flex;align-items:center;gap:10px">
                    <div style="background:#E35106;color:#fff;font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;padding:3px 5px;border-radius:2px">{type}</div>
                    <span style="font-size:14px;color:#111">{name}</span>
                  </div>
                  <div style="display:flex;align-items:center;gap:12px">
                    <span style="font-size:12px;color:#8A8A8A;font-family:'JetBrains Mono',monospace">{size}</span>
                    <button class="btn btn-ghost btn-sm">Baixar</button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer settings={settings} />
</BaseLayout>

<script define:vars={{ slug }} is:inline>
  window.__BRA_SLUG__ = slug;
</script>

<script is:inline>
  document.addEventListener('alpine:init', function () {
    Alpine.data('compareBtn', function () {
      return {
        isCompared: false,
        slug: '',

        init: function () {
          this.slug = window.__BRA_SLUG__ || '';
          try {
            var s = sessionStorage.getItem('bra-compare');
            if (s) this.isCompared = JSON.parse(s).includes(this.slug);
          } catch (e) {}
        },

        toggle: function () {
          try {
            var s    = sessionStorage.getItem('bra-compare');
            var list = s ? JSON.parse(s) : [];
            if (this.isCompared) {
              list = list.filter(function (id) { return id !== this.slug; }.bind(this));
            } else if (list.length < 4) {
              list.push(this.slug);
            }
            sessionStorage.setItem('bra-compare', JSON.stringify(list));
            this.isCompared = list.includes(this.slug);
          } catch (e) {}
        },
      };
    });
  });
</script>
