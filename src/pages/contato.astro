---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getSiteSettings } from '../lib/queries';

const settings = await getSiteSettings();

// Pre-fill product if passed via URL
const productParam = Astro.url.searchParams.get('produto') || '';
const productName = Astro.url.searchParams.get('nome') || '';
---

<BaseLayout
  title="Contato — Solicitar Orçamento"
  description="Entre em contato com a BRALARMSEG. Solicite orçamento, análise técnica ou fale com nossa equipe especializada em iluminação LED industrial."
>
  <Header currentPage="contato" />

  <main>
    <div class="page-header">
      <div class="container">
        <nav class="breadcrumb" aria-label="Navegação estrutural">
          <a href="/" class="breadcrumb__item">BRALARMSEG</a>
          <span class="breadcrumb__sep">/</span>
          <span class="breadcrumb__item breadcrumb__item--current">Contato</span>
        </nav>
        <p class="page-header__eyebrow" style="margin-top:10px">Fale conosco</p>
        <h1 class="page-header__title">SOLICITAR ORÇAMENTO</h1>
        <p class="page-header__sub">Nossa equipe técnica responde em até 24 horas úteis.</p>
      </div>
    </div>

    <section style="padding:80px 0;background:#F5F5F5">
      <div class="container contact-grid">

        <!-- Contact info card -->
        <div class="contact-info">
          <div>
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:700;color:#fff;margin-bottom:4px">
              BR<span style="color:#E35106">A</span>LARMSEG
            </div>
            <div style="font-size:11px;color:#5A7AA0;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:20px">
              Segurança e Emergência
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <div class="contact-info__label">Endereço</div>
              <div class="contact-info__value" set:html={settings.address.replace('\n', '<br>')} />
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.64A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/>
              </svg>
            </div>
            <div>
              <div class="contact-info__label">Telefones</div>
              <div class="contact-info__value">
                {settings.phone1}<br/>
                {settings.phone2}<br/>
                {settings.phone3} | {settings.phone4}
              </div>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <div class="contact-info__label">E-mail</div>
              <div class="contact-info__value">{settings.email}</div>
            </div>
          </div>

          <a
            href={`https://wa.me/${settings.whatsapp}?text=Olá,%20gostaria%20de%20solicitar%20um%20orçamento.`}
            target="_blank"
            rel="noopener"
            style="display:flex;align-items:center;gap:10px;background:#25D366;color:#fff;padding:12px 18px;border-radius:3px;text-decoration:none;font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;margin-top:8px"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            FALAR NO WHATSAPP
          </a>
        </div>

        <!-- Contact form -->
        <div style="background:#fff;border-radius:4px;padding:40px;box-shadow:0 2px 8px rgba(0,0,0,0.06)">
          <h2 style="font-family:'Barlow Condensed',sans-serif;font-size:24px;font-weight:700;color:#111;margin-bottom:24px">
            {productParam ? `Orçamento: ${productParam.toUpperCase()}` : 'Solicitar Orçamento'}
          </h2>

          <!-- Single Alpine root wraps form + success state -->
          <div x-data="contactForm()">
            <form @submit.prevent="submit()" x-show="!sent" style="display:flex;flex-direction:column;gap:16px">
              <div class="field">
                <label for="empresa">Nome da empresa *</label>
                <input
                  type="text"
                  id="empresa"
                  name="empresa"
                  placeholder="Ex: Metalúrgica São Paulo Ltda."
                  required
                  x-model="form.empresa"
                />
              </div>

              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <div class="field">
                  <label for="nome">Nome do responsável</label>
                  <input type="text" id="nome" name="nome" placeholder="Carlos Mendes" x-model="form.nome" />
                </div>
                <div class="field">
                  <label for="telefone">Telefone / WhatsApp *</label>
                  <input type="tel" id="telefone" name="telefone" placeholder="(41) 99999-9999" required x-model="form.telefone" />
                </div>
              </div>

              <div class="field">
                <label for="email">E-mail</label>
                <input type="email" id="email" name="email" placeholder="contato@empresa.com.br" x-model="form.email" />
              </div>

              <div class="field">
                <label for="segmento">Segmento</label>
                <select id="segmento" name="segmento" x-model="form.segmento">
                  <option value="">Selecione...</option>
                  <option>Galpão Industrial</option>
                  <option>Frigorífico</option>
                  <option>Centro Logístico</option>
                  <option>Estacionamento</option>
                  <option>Quadra Esportiva</option>
                  <option>Supermercado / Varejo</option>
                  <option>Porto / Aeroporto</option>
                  <option>Off-grid / Solar</option>
                  <option>Outro</option>
                </select>
              </div>

              {productParam && (
                <div class="field">
                  <label for="produto">Produto de interesse</label>
                  <input type="text" id="produto" name="produto" value={productParam} x-model="form.produto" />
                </div>
              )}

              <div class="field">
                <label for="mensagem">Descrição do projeto</label>
                <textarea
                  id="mensagem"
                  name="mensagem"
                  placeholder="Descreva o ambiente, pé-direito, área total, quantidade de pontos de luz..."
                  rows="4"
                  x-model="form.mensagem"
                ></textarea>
              </div>

              <div x-show="error" class="alert alert--error" x-text="error"></div>

              <button
                type="submit"
                class="btn btn-primary"
                style="font-size:15px"
                :disabled="loading"
              >
                <span x-show="!loading">ENVIAR SOLICITAÇÃO</span>
                <span x-show="loading">Enviando...</span>
              </button>

              <p style="font-size:12px;color:#7A7A7A;text-align:center">
                Resposta em até 24 horas úteis. Seus dados são tratados com sigilo.
              </p>
            </form>

            <!-- Success state (inside same Alpine root) -->
            <div x-show="sent" style="text-align:center;padding:40px 0">
              <div style="width:56px;height:56px;background:#D1FAE5;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#065F46" stroke-width="2.5">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <h3 style="font-family:'Barlow Condensed',sans-serif;font-size:24px;font-weight:700;color:#111;margin-bottom:8px">
                Solicitação enviada!
              </h3>
              <p style="font-size:14px;color:#5A5A5A;margin-bottom:24px">
                Nossa equipe técnica entrará em contato em até 24 horas úteis.
              </p>
              <a href="/produtos" class="btn btn-primary">VER MAIS PRODUTOS</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer settings={settings} />
</BaseLayout>

<script define:vars={{ productParam }} is:inline>
  window.__INITIAL_PRODUTO__ = productParam;
</script>

<script is:inline>
  document.addEventListener('alpine:init', function () {
    Alpine.data('contactForm', function () {
      return {
        sent:    false,
        loading: false,
        error:   '',
        form: {
          empresa:  '',
          nome:     '',
          telefone: '',
          email:    '',
          segmento: '',
          produto:  window.__INITIAL_PRODUTO__ || '',
          mensagem: '',
        },

        submit: async function () {
          this.loading = true;
          this.error   = '';
          try {
            var res = await fetch('/api/contact', {
              method:  'POST',
              headers: { 'Content-Type': 'application/json' },
              body:    JSON.stringify(this.form),
            });
            if (res.ok) {
              this.sent = true;
            } else {
              var data = await res.json().catch(function () { return {}; });
              this.error = data.message || 'Erro ao enviar. Tente novamente ou ligue para (41) 99274-4818.';
            }
          } catch (e) {
            this.error = 'Sem conexão. Tente novamente ou ligue para (41) 99274-4818.';
          } finally {
            this.loading = false;
          }
        },
      };
    });
  });
</script>
