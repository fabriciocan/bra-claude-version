---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProductsByIds, getSiteSettings } from '../lib/queries';

const idsParam = Astro.url.searchParams.get('ids') || '';
const ids = idsParam.split(',').filter(Boolean).slice(0, 4);

const [products, settings] = await Promise.all([
  getProductsByIds(ids),
  getSiteSettings(),
]);

// All unique spec keys across selected products
const allKeys = [...new Set(products.flatMap(p => p.specs.map(s => s.key)))];
---

<BaseLayout
  title="Comparar Produtos"
  description="Compare as especificações técnicas de produtos LED BRATECH lado a lado."
>
  <Header currentPage="produtos" />

  <main>
    <!-- Dark header -->
    <div style="background:#0A1628;padding:28px 0">
      <div class="container" style="display:flex;align-items:center;gap:24px;flex-wrap:wrap">
        <a href="/produtos" style="font-family:'Barlow',sans-serif;font-size:12px;font-weight:600;color:#A0B4CC;text-decoration:none;display:flex;align-items:center;gap:4px;padding:6px 10px;border-radius:3px;border:1px solid rgba(255,255,255,0.12)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          Voltar ao catálogo
        </a>
        <div>
          <div style="font-size:11px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#E35106;margin-bottom:4px">Comparação</div>
          <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(28px,4vw,36px);font-weight:800;color:#fff;letter-spacing:-0.01em;margin:0">
            COMPARAR {products.length} PRODUTOS
          </h1>
        </div>
      </div>
    </div>

    <div class="container" style="padding-top:24px;padding-bottom:60px">
      {products.length === 0 ? (
        <div class="no-results">
          <div class="no-results__icon">○</div>
          <div class="no-results__title">Nenhum produto selecionado</div>
          <p>Vá ao catálogo e selecione produtos para comparar.</p>
          <a href="/produtos" class="btn btn-primary" style="margin-top:16px">Ver Catálogo</a>
        </div>
      ) : products.length < 2 ? (
        <div class="no-results">
          <div class="no-results__title">Selecione ao menos 2 produtos</div>
          <p>Você selecionou apenas {products.length} produto. Adicione mais para comparar.</p>
          <a href="/produtos" class="btn btn-primary" style="margin-top:16px">Adicionar produtos</a>
        </div>
      ) : (
        <div class="comparison-wrap">
          <table class="comparison-table">
            <thead>
              <tr>
                <th class="comparison-row-label" style="border-bottom:2px solid #111;background:#F5F5F5;min-width:160px"></th>
                {products.map(p => (
                  <th class="comparison-header" style="vertical-align:top;padding:16px 20px;min-width:200px">
                    <div style="display:flex;flex-direction:column;gap:4px">
                      <div style="width:100%;height:100px;background:#FAFAFA;border-radius:2px;display:flex;align-items:center;justify-content:center;margin-bottom:8px;overflow:hidden">
                        <img
                          src={p.imageUrl || '/placeholder-product.jpg'}
                          alt={p.fullName}
                          style="max-width:100%;max-height:100%;object-fit:contain;padding:8px"
                        />
                      </div>
                      <div style="font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#E35106">{p.category}</div>
                      <div style="font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;color:#111;line-height:1.2">{p.name}</div>
                      {p.badge && (
                        <span class="badge" style={`background:${p.badgeColor || '#E35106'};display:inline-block;margin-top:2px`}>{p.badge}</span>
                      )}
                      <a href={`/produtos/${p.slug}`} style="font-size:11px;color:#7A7A7A;text-decoration:underline;margin-top:4px">
                        Ver detalhes
                      </a>
                    </div>
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {allKeys.map((key, i) => (
                <tr style={`background:${i % 2 === 0 ? '#fff' : '#FAFAFA'}`}>
                  <td class="comparison-row-label">{key}</td>
                  {products.map(p => {
                    const spec = p.specs.find(s => s.key === key);
                    return (
                      <td class="comparison-cell">
                        {spec
                          ? <span style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#111;font-weight:500">{spec.value}</span>
                          : <span style="color:#BABABA;font-size:13px">—</span>
                        }
                      </td>
                    );
                  })}
                </tr>
              ))}
              <!-- CTA row -->
              <tr style="background:#F5F5F5">
                <td style="padding:12px 16px;border:none"></td>
                {products.map(p => (
                  <td style="padding:14px 20px;border:none">
                    <a href={`/contato?produto=${p.slug}`} class="btn btn-primary" style="width:100%;text-align:center;display:block">
                      Solicitar Orçamento
                    </a>
                  </td>
                ))}
              </tr>
            </tbody>
          </table>
        </div>
      )}
    </div>
  </main>

  <Footer settings={settings} />
</BaseLayout>
